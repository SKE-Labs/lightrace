generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("users")
}

model Project {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  apiKeys      ApiKey[]
  traces       Trace[]
  observations Observation[]
  scores       Score[]

  @@map("projects")
}

model ApiKey {
  id               String   @id @default(cuid())
  publicKey        String   @unique @map("public_key")
  hashedSecretKey  String   @map("hashed_secret_key")
  displaySecretKey String   @map("display_secret_key")
  note             String?
  projectId        String   @map("project_id")
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([publicKey])
  @@map("api_keys")
}

model Trace {
  id        String   @id
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  name      String?
  input     Json?
  output    Json?
  metadata  Json?
  sessionId String?  @map("session_id")
  userId    String?  @map("user_id")
  release   String?
  version   String?
  tags      String[] @default([])
  public    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  observations Observation[]
  scores       Score[]

  @@index([projectId, timestamp(sort: Desc)])
  @@index([sessionId])
  @@index([name])
  @@map("traces")
}

enum ObservationType {
  SPAN
  GENERATION
  EVENT
}

enum ObservationLevel {
  DEBUG
  DEFAULT
  WARNING
  ERROR
}

model Observation {
  id                  String           @id
  traceId             String           @map("trace_id")
  trace               Trace            @relation(fields: [traceId], references: [id], onDelete: Cascade)
  projectId           String           @map("project_id")
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type                ObservationType
  name                String?
  startTime           DateTime         @default(now()) @map("start_time")
  endTime             DateTime?        @map("end_time")
  completionStartTime DateTime?        @map("completion_start_time")
  input               Json?
  output              Json?
  metadata            Json?
  model               String?
  modelParameters     Json?            @map("model_parameters")
  parentObservationId String?          @map("parent_observation_id")
  level               ObservationLevel @default(DEFAULT)
  statusMessage       String?          @map("status_message")
  version             String?
  promptTokens        Int              @default(0) @map("prompt_tokens")
  completionTokens    Int              @default(0) @map("completion_tokens")
  totalTokens         Int              @default(0) @map("total_tokens")
  inputCost           Float?           @map("input_cost")
  outputCost          Float?           @map("output_cost")
  totalCost           Float?           @map("total_cost")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at")

  scores Score[]

  @@index([traceId])
  @@index([projectId, startTime(sort: Desc)])
  @@index([parentObservationId])
  @@map("observations")
}

model Score {
  id            String       @id @default(cuid())
  traceId       String       @map("trace_id")
  trace         Trace        @relation(fields: [traceId], references: [id], onDelete: Cascade)
  observationId String?      @map("observation_id")
  observation   Observation? @relation(fields: [observationId], references: [id], onDelete: SetNull)
  projectId     String       @map("project_id")
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  value         Float
  source        String       @default("API")
  comment       String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at")

  @@index([traceId])
  @@index([observationId])
  @@index([projectId, name])
  @@map("scores")
}
