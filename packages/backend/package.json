{
  "name": "@lightrace/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "@lightrace/shared": "workspace:*",
    "@prisma/client": "^7.5.0",
    "@trpc/server": "^11.12.0",
    "hono": "^4.8.3",
    "ioredis": "^5.6.1",
    "protobufjs": "^8.0.0",
    "superjson": "^2.2.6",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/ws": "^8",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
