generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  memberships     ProjectMembership[]
  invitationsSent MembershipInvitation[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  apiKeys            ApiKey[]
  traces             Trace[]
  observations       Observation[]
  toolRegistrations  ToolRegistration[]
  memberships        ProjectMembership[]
  invitations        MembershipInvitation[]

  @@map("projects")
}

model ApiKey {
  id               String   @id @default(cuid())
  publicKey        String   @unique @map("public_key")
  hashedSecretKey  String   @map("hashed_secret_key")
  displaySecretKey String   @map("display_secret_key")
  note             String?
  projectId        String   @map("project_id")
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([publicKey])
  @@map("api_keys")
}

model Trace {
  id        String   @id
  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timestamp DateTime @default(now())
  name      String?
  input     Json?
  output    Json?
  metadata  Json?
  sessionId String?  @map("session_id")
  userId    String?  @map("user_id")
  release   String?
  version   String?
  tags      String[] @default([])
  public    Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // Denormalized aggregates (maintained by ingestion)
  totalTokens      Int              @default(0) @map("total_tokens")
  totalCost        Float?           @map("total_cost")
  latencyMs        Int?             @map("latency_ms")
  primaryModel     String?          @map("primary_model")
  observationCount Int              @default(0) @map("observation_count")
  level            ObservationLevel @default(DEFAULT)

  observations Observation[]

  @@index([projectId, timestamp(sort: Desc)])
  @@index([projectId, level, timestamp(sort: Desc)])
  @@index([projectId, userId])
  @@index([sessionId])
  @@index([name])
  @@map("traces")
}

enum ObservationType {
  SPAN
  GENERATION
  EVENT
  TOOL
  CHAIN
}

enum ObservationLevel {
  DEBUG
  DEFAULT
  WARNING
  ERROR
}

model Observation {
  id                  String           @id
  traceId             String           @map("trace_id")
  trace               Trace            @relation(fields: [traceId], references: [id], onDelete: Cascade)
  projectId           String           @map("project_id")
  project             Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type                ObservationType
  name                String?
  startTime           DateTime         @default(now()) @map("start_time")
  endTime             DateTime?        @map("end_time")
  completionStartTime DateTime?        @map("completion_start_time")
  input               Json?
  output              Json?
  metadata            Json?
  model               String?
  modelParameters     Json?            @map("model_parameters")
  parentObservationId String?          @map("parent_observation_id")
  level               ObservationLevel @default(DEFAULT)
  statusMessage       String?          @map("status_message")
  version             String?
  promptTokens        Int              @default(0) @map("prompt_tokens")
  completionTokens    Int              @default(0) @map("completion_tokens")
  totalTokens         Int              @default(0) @map("total_tokens")
  inputCost           Float?           @map("input_cost")
  outputCost          Float?           @map("output_cost")
  totalCost           Float?           @map("total_cost")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @default(now()) @updatedAt @map("updated_at")

  @@index([traceId])
  @@index([traceId, type])
  @@index([traceId, level])
  @@index([projectId, startTime(sort: Desc)])
  @@index([parentObservationId])
  @@map("observations")
}

model ToolRegistration {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sdkInstanceId String   @map("sdk_instance_id")
  toolName      String   @map("tool_name")
  inputSchema   Json?    @map("input_schema")
  status        String   @default("online")
  lastHeartbeat DateTime @default(now()) @map("last_heartbeat")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([projectId, sdkInstanceId, toolName])
  @@index([projectId, status])
  @@map("tool_registrations")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model ProjectMembership {
  id        String     @id @default(cuid())
  userId    String     @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String     @map("project_id")
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @default(now()) @updatedAt @map("updated_at")

  @@unique([userId, projectId])
  @@index([projectId])
  @@map("project_memberships")
}

model MembershipInvitation {
  id              String           @id @default(cuid())
  email           String
  projectId       String           @map("project_id")
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role            MemberRole       @default(MEMBER)
  invitedByUserId String           @map("invited_by_user_id")
  invitedBy       User             @relation(fields: [invitedByUserId], references: [id])
  token           String           @unique
  expiresAt       DateTime         @map("expires_at")
  status          InvitationStatus @default(PENDING)
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([email, projectId])
  @@map("membership_invitations")
}
