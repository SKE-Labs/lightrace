# ── Lightrace Docker Compose ─────────────────────────────────────
# Copy to .env and customize as needed.
# All values below are development defaults.

# Gateway (Caddy reverse proxy)
GATEWAY_PORT=3000
# Set a real domain for automatic HTTPS (e.g. trace.mycompany.com)
# LIGHTRACE_DOMAIN=localhost

# Public URL (used for Auth.js callbacks — set to your domain in production)
PUBLIC_URL=http://localhost:3000

# Database
DB_PASSWORD=lightrace

# Secrets (generate random values for production)
AUTH_SECRET=dev-auth-secret
INTERNAL_SECRET=dev-internal-secret

# Image overrides (default: latest from GHCR)
# BACKEND_IMAGE=ghcr.io/lightrace/backend:0.1.0
# FRONTEND_IMAGE=ghcr.io/lightrace/frontend:0.1.0
