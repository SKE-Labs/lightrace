{
  "name": "lightrace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,css}\"",
    "db:generate": "pnpm --filter @lightrace/shared db:generate",
    "db:migrate": "pnpm --filter @lightrace/shared db:migrate",
    "db:seed": "pnpm --filter @lightrace/shared db:seed",
    "db:reset": "pnpm --filter @lightrace/shared db:reset",
    "db:studio": "pnpm --filter @lightrace/shared db:studio",
    "prepare": "husky",
    "precommit": "lint-staged"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "turbo": "^2.5.4"
  },
  "lint-staged": {
    "*.{ts,tsx,css,json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "@prisma/client"
    ]
  }
}
